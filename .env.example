# =============================================================
# RESINOVA — Çevre Değişkenleri Şablonu
# =============================================================
# Bu dosyayı ".env.local" (local) veya ".env" (sunucu) olarak
# kopyalayıp değerleri doldurun.
#
# Vercel'de: Project Settings > Environment Variables
# Plesk'te:  Node.js > Environment Variables
# =============================================================

# ─── Uygulama URL'si (ZORUNLU) ────────────────────────────
# Sonunda / olmadan. Vercel'de otomatik atanır.
NEXT_PUBLIC_SITE_URL=https://www.resinova.com.tr

# ─── Ortam ────────────────────────────────────────────────
NODE_ENV=production

# ─── Güvenlik / JWT ──────────────────────────────────────
# openssl rand -base64 32 ile üretin
JWT_SECRET=BURAYA_EN_AZ_32_KARAKTER_RASTGELE_ANAHTAR

# ─── Veritabanı (ileriye dönük) ───────────────────────────
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=mssbey
# DB_USER=mssbey
# DB_PASSWORD=

# ─── E-posta / SMTP ───────────────────────────────────────
# SMTP_HOST=mail.resinova.com.tr
# SMTP_PORT=587
# SMTP_USER=info@resinova.com.tr
# SMTP_PASS=
# SMTP_FROM="RESINOVA <info@resinova.com.tr>"

# ─── Ödeme Sağlayıcısı (ileriye dönük) ───────────────────
# IYZICO_API_KEY=
# IYZICO_SECRET_KEY=
# IYZICO_BASE_URL=https://api.iyzipay.com

# ─── Analytics ────────────────────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
